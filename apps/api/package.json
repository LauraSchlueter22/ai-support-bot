{
  "name": "@ai-support-bot/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- tsx src/db/migrate.ts",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio"
  },
  "dependencies": {
    "@ai-support-bot/schemas": "workspace:*",
    "@hono/node-server": "^1.11.0",
    "@hono/zod-validator": "^0.7.6",
    "ai": "^6.0.170",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "0.45.2",
    "hono": "^4.3.0",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "openai": "^6.35.0",
    "pg": "^8.11.0",
    "pnpm": "^10.33.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
